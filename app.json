{
  "expo": {
    "name": "The Church of Jesus Christ OF LATTER-DAY SAINTS",
    "slug": "cojc-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#592569"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.cojclds.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#1D9E75"
      },
      "package": "com.cojclds.app"
    },
    "scheme": "cojc-app",
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#592569",
          "image": "./assets/icon.png",
          "imageWidth": 220
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
