#!/bin/bash
set -e

echo "Creating folder structure..."
mkdir -p lib
mkdir -p app/\(auth\)
mkdir -p app/\(tabs\)
mkdir -p app/article
mkdir -p app/note
mkdir -p app/event
mkdir -p app/sermon

echo "Writing package.json..."
cat > package.json << 'PKGJSON'
